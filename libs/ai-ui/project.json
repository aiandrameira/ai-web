{
    "name": "ai-ui",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/ai-ui/src",
    "prefix": "lib",
    "projectType": "library",
    "tags": [],
    "targets": {
        "build": {
            "executor": "@nx/angular:ng-packagr-lite",
            "outputs": [
                "{workspaceRoot}/dist/{projectRoot}"
            ],
            "options": {
                "project": "libs/ai-ui/ng-package.json"
            },
            "configurations": {
                "production": {
                    "tsConfig": "libs/ai-ui/tsconfig.lib.prod.json"
                },
                "development": {
                    "tsConfig": "libs/ai-ui/tsconfig.lib.json"
                }
            },
            "defaultConfiguration": "production"
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        }
    }
}